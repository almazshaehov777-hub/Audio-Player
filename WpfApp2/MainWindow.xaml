<Window x:Class="WpfApp2.MainWindow"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" WindowStyle="None">
    <Grid x:Name="grid" Height="450" VerticalAlignment="Top">
        <MediaElement x:Name="mediaElement" HorizontalAlignment="Left" Height="100" Margin="684,12,0,0" VerticalAlignment="Top" Width="100" Volume="1"/>
        <ListBox x:Name="listBox" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,0,542,0" SelectionChanged="listBox_SelectionChanged" Background="{x:Null}"/>

        <Button Content="Добавить Музыку" HorizontalAlignment="Left" Margin="258,0,0,0" VerticalAlignment="Top" Click="Button_Click_1" Cursor="Hand" FontFamily="Bahnschrift" Height="24" FontSize="14" Background="#FFE0E0E0"/>
        <StackPanel x:Name="stackPanel" Margin="0,349,0,0">
            <StackPanel.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF8A8A8A"/>
                    <GradientStop Color="#FFB9B9B9" Offset="1"/>
                    <GradientStop Color="#FF737373" Offset="0"/>
                    <GradientStop Color="#FF757575" Offset="0"/>
                </LinearGradientBrush>
            </StackPanel.Background>
        </StackPanel>
        <Button x:Name="b" Content="▶" HorizontalAlignment="Center" Margin="0,364,0,0" VerticalAlignment="Top" FontSize="38" Width="60" Height="60" Click="Button_Click_2" Cursor="Hand">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Slider x:Name="slider" HorizontalAlignment="Left" Margin="9,390,0,0" VerticalAlignment="Top" Width="120" Maximum="1" SmallChange="1" Value="1"/>
        <Label x:Name="label1" Content="" HorizontalAlignment="Left" Margin="135,383,0,0" VerticalAlignment="Top" Foreground="White" FontSize="16"/>
        <Slider x:Name="slider2" HorizontalAlignment="Left" Margin="522,390,0,0" VerticalAlignment="Top" Width="150" ValueChanged="Slider_ValueChanged_1" Background="#00000000" BorderBrush="#00000000" Foreground="#FFE5E5E5"/>
        <Button Content="Выйти" HorizontalAlignment="Left" Margin="725,0,0,0" VerticalAlignment="Top" Click="Button_Click_3" Height="36" Cursor="Hand" Width="75" FontSize="16" FontFamily="Bahnschrift">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFFF6464"/>
                    <GradientStop Color="Red" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="MuseSwiperRight" Content="&gt;" HorizontalAlignment="Left" Margin="449,369,0,0" VerticalAlignment="Top" FontSize="24" Width="50" Height="50" Click="Button_Click_4" Background="White" Cursor="Hand"/>
        <Button x:Name="MuseSwiperLeft" Content="&lt;" HorizontalAlignment="Left" Margin="300,369,0,0" VerticalAlignment="Top" FontSize="24" Width="50" Height="50" Click="Button_Click_5" Background="White" Cursor="Hand"/>
        <Label x:Name="label2" Content="Label" HorizontalAlignment="Left" Margin="677,384,0,0" VerticalAlignment="Top" Foreground="White" FontSize="16" FontFamily="Bahnschrift"/>

    </Grid>
</Window>
